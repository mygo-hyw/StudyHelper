<Window x:Class="StudyHelper.ToastNotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="任务提醒"
        Width="320"
        Height="Auto"
        MaxHeight="150"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        WindowStartupLocation="Manual">

    <!-- 主背景：磨砂效果卡片 -->
    <Border Background="#F0FFFFFF" BorderBrush="#FF2C3E50" BorderThickness="1" CornerRadius="10" Padding="16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 关闭按钮（右上角） -->
            <Button Grid.Row="0" HorizontalAlignment="Right" VerticalAlignment="Top"
                    Width="24" Height="24" Background="Transparent" BorderThickness="0"
                    Foreground="#FF666666" FontSize="18" Click="CloseButton_Click" Cursor="Hand"
                    Content="×" Padding="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#FFDDDDDD"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <!-- 任务标题 -->
            <TextBlock Grid.Row="0" Text="学习提醒" FontSize="14" FontWeight="Bold"
                       Foreground="#FF2C3E50" VerticalAlignment="Center" Margin="0,0,30,0"/>

            <!-- 任务详情 -->
            <StackPanel Grid.Row="1" Margin="0,10,0,10">
                <TextBlock x:Name="TaskTitleTextBlock" FontSize="13" FontWeight="SemiBold" 
                           Foreground="#FF1A252F" TextWrapping="Wrap" Margin="0,0,0,6"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                    <TextBlock Text="优先级: " FontSize="12" Foreground="#FF666666"/>
                    <TextBlock x:Name="PriorityTextBlock" FontSize="12" Foreground="#FF2563EB" FontWeight="Bold"/>
                </StackPanel>
            </StackPanel>

            <!-- 按钮区域 -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                <!-- 暂时忽略 1 小时按钮 -->
                <Button x:Name="IgnoreButton" Width="120" Height="34" Margin="0,0,8,0"
                        Background="#FFF5F5F5" BorderBrush="#FFCCCCCC" BorderThickness="1"
                        Foreground="#FF333333" FontSize="12" Click="IgnoreButton_Click" Cursor="Hand"
                        Content="暂时忽略 1h">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FFEEEEEE"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#FFDDDDDD"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>

                <!-- 知道了按钮 -->
                <Button x:Name="AckButton" Width="80" Height="34"
                        Background="#FF2563EB" BorderThickness="0"
                        Foreground="White" FontSize="12" Click="AckButton_Click" Cursor="Hand"
                        Content="知道了">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="5">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FF1D4ED8"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#FF1E40AF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
