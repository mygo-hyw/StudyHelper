<Window x:Class="StudyHelper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:StudyHelper.Converters"
        Title="桌面看板" Width="380"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent" 
        ShowInTaskbar="False"
        SizeToContent="Height"
        MinHeight="120"
        Opacity="{Binding WindowOpacity}"
        WindowStartupLocation="Manual" Left="50" Top="50">
    <Window.Resources>
        <local:ProgressWidthConverter x:Key="ProgressWidthConverter"/>
    </Window.Resources>

    <!-- 背景色和框色完全受 DataContext 控制器控制 -->
    <Border Background="{Binding WidgetBackground}" 
            CornerRadius="12" Padding="15" 
            BorderBrush="{Binding WidgetBorderBrush}" BorderThickness="1.5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 标题栏：显示"今日学习养成目标"、关闭按钮、连续打卡天数、任务完成进度 -->
            <Grid Grid.Row="0" Margin="0,0,0,8" Height="30" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Cursor="SizeAll">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 标题 -->
                <TextBlock Grid.Column="0" Text="今日学习养成目标" FontSize="14" FontWeight="Bold" 
                           Foreground="{Binding WidgetTextColor}" VerticalAlignment="Center"/>

                <!-- 连续打卡天数 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="4,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="打卡: " FontSize="11" Foreground="{Binding WidgetTextColor}"/>
                    <TextBlock Text="{Binding StreakDays, StringFormat={}{0}天}" FontSize="11" FontWeight="Bold" 
                               Foreground="#FF6B9FE0"/>
                </StackPanel>

                <!-- 总任务完成进度 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="4,0,0,0" VerticalAlignment="Center">
                    <TextBlock Text="进度: " FontSize="11" Foreground="{Binding WidgetTextColor}"/>
                    <TextBlock Text="{Binding CompletionRate, StringFormat={}{0:F1}%}" FontSize="11" FontWeight="Bold" 
                               Foreground="#28A745"/>
                </StackPanel>

                <!-- 关闭按钮(×) -->
                <Button Grid.Column="3" Content="×" Click="CloseButton_Click" 
                        Width="26" Height="26" Margin="4,0,0,0"
                        Background="Transparent" BorderThickness="0" 
                        Foreground="{Binding WidgetTextColor}" FontSize="16" FontWeight="Bold"
                        Cursor="Hand" VerticalAlignment="Center">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}" 
                                    CornerRadius="4">
                                <ContentPresenter HorizontalAlignment="Center" 
                                                  VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#FFE0E0E0"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#FFC0C0C0"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- 完成度进度条 -->
            <StackPanel Grid.Row="1" Margin="0,0,0,10">
                <ProgressBar Value="{Binding CompletionRate}" Maximum="100" Height="8"
                             Background="#30000000" Foreground="#28A745"
                             BorderThickness="0">
                    <ProgressBar.Style>
                        <Style TargetType="ProgressBar">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="ProgressBar">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                            <Grid x:Name="PART_Track" ClipToBounds="True">
                                                <Rectangle x:Name="PART_Indicator"
                                                           Fill="{TemplateBinding Foreground}"
                                                           HorizontalAlignment="Left"
                                                           RadiusX="3" RadiusY="3" Margin="1">
                                                    <Rectangle.Width>
                                                        <MultiBinding>
                                                            <MultiBinding.Converter>
                                                                <local:ProgressWidthConverter/>
                                                            </MultiBinding.Converter>
                                                            <Binding Path="Value" RelativeSource="{RelativeSource TemplatedParent}"/>
                                                            <Binding Path="Maximum" RelativeSource="{RelativeSource TemplatedParent}"/>
                                                            <Binding Path="ActualWidth" ElementName="PART_Track"/>
                                                        </MultiBinding>
                                                    </Rectangle.Width>
                                                </Rectangle>
                                            </Grid>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </ProgressBar.Style>
                </ProgressBar>
                <TextBlock Text="{Binding CompletionRate, StringFormat=已完成: {0:F1}%}" 
                           FontSize="10" Foreground="#888888" Margin="0,3,0,0"/>
            </StackPanel>

            <!-- 核心：支持层级折叠展开的任务列表 -->
            <ListBox Grid.Row="2" ItemsSource="{Binding Tasks}" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled" ScrollViewer.VerticalScrollBarVisibility="Disabled">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <!-- 每个大任务采用可折叠 Expander 包装 -->
                        <Expander Margin="0,0,0,10" HorizontalContentAlignment="Stretch">

                            <Expander.Header>
                                <!-- 
      核心修改：添加 HorizontalAlignment 属性，并使用 OneWayToSource 逆向绑定。
      这行代码会强制将父级 ContentPresenter 的对齐方式修改为 Stretch，从而彻底解锁横向拉伸！
    -->
                                <DockPanel LastChildFill="False"
               HorizontalAlignment="{Binding HorizontalAlignment, RelativeSource={RelativeSource AncestorType={x:Type ContentPresenter}}, Mode=OneWayToSource}">

                                    <!-- 左侧：标题 + 优先级|截止日期 -->
                                    <StackPanel DockPanel.Dock="Left" Orientation="Vertical">
                                        <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="Bold" 
                       Foreground="{Binding DataContext.WidgetTextColor, RelativeSource={RelativeSource AncestorType=Window}}"
                       TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Text="{Binding PriorityDueDateDisplay}" FontSize="10" Foreground="#888888"/>
                                    </StackPanel>

                                    <!-- 右侧：剩余天数紧贴右边缘，✅ 紧跟其后 -->
                                    <StackPanel DockPanel.Dock="Right" VerticalAlignment="Center" Orientation="Horizontal" Margin="0,0,5,0">
                                        <!-- 剩余天数显示 -->
                                        <TextBlock Text="{Binding RemainingDaysDisplay}" 
                       FontSize="11" FontWeight="Bold"
                       VerticalAlignment="Center"
                       Margin="0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="#888888"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RemainingDays}" Value="0">
                                                            <Setter Property="Foreground" Value="#FFA500"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding RemainingDays}" Value="-1">
                                                            <Setter Property="Foreground" Value="#FF4444"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <!-- 已全部打卡 -->
                                        <TextBlock Text="✅" Foreground="#28A745" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"
                       Margin="4,0,0,0"
                       Visibility="{Binding IsCompleted, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                    </StackPanel>
                                </DockPanel>
                            </Expander.Header>

                            <!-- 内部嵌套展现对应的子任务列表 -->
                            <ItemsControl ItemsSource="{Binding SubTasks}" Margin="20,5,0,5">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,4,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>


                                            <!-- 子任务一键打卡按钮 -->
                                            <Button Grid.Column="0"
                                                    Content="打卡"
                                                    Command="{Binding DataContext.CompleteSubTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                    CommandParameter="{Binding}"
                                                    Width="52"
                                                    Height="26"
                                                    Padding="0"
                                                    Margin="0"
                                                    VerticalAlignment="Center"
                                                    Background="#F8FFFFFF"
                                                    BorderBrush="#FF000000"
                                                    BorderThickness="1"
                                                    Foreground="#17212F"
                                                    FontSize="12"
                                                    FontWeight="SemiBold"
                                                    Cursor="Hand"
                                                    Opacity="0.98">
                                                <Button.Template>
                                                    <ControlTemplate TargetType="Button">
                                                        <Border Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="13">
                                                            <ContentPresenter HorizontalAlignment="Center"
                                                                              VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="Background" Value="#FFFFFFFF"/>
                                                            </Trigger>
                                                            <Trigger Property="IsPressed" Value="True">
                                                                <Setter Property="Background" Value="#EDEDED"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Button.Template>
                                            </Button>



                                            <TextBlock Grid.Column="1" Text="{Binding Title}" Margin="8,0,0,0" FontSize="12" VerticalAlignment="Center"
                                                       Foreground="{Binding DataContext.WidgetTextColor, RelativeSource={RelativeSource AncestorType=Window}}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                <!-- 打卡后文字自动灰色斜体划线 -->
                                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                                <Setter Property="Foreground" Value="#888888"/>
                                                            </DataTrigger>
                                                            <!-- 修正：将原本错误的 </Style.Triggers> 改为 </DataTrigger> 闭合 -->
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>


                        </Expander>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Border>
</Window>