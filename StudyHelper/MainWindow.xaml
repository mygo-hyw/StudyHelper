<Window x:Class="StudyHelper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="桌面看板" Height="500" Width="380"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent" 
        ShowInTaskbar="False"
        Opacity="{Binding WindowOpacity}"
        WindowStartupLocation="Manual" Left="50" Top="50">

    <!-- 背景色和框色完全受 DataContext 控制器控制 -->
    <Border Background="{Binding WidgetBackground}" 
            CornerRadius="12" Padding="15" 
            BorderBrush="{Binding WidgetBorderBrush}" BorderThickness="1.5">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,15" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <TextBlock Text="今日学习养成目标" FontWeight="Bold" FontSize="16" Foreground="{Binding WidgetTextColor}"/>
                <Button Content="×" HorizontalAlignment="Right" FontSize="18" Background="Transparent" Foreground="{Binding WidgetTextColor}" BorderThickness="0" Cursor="Hand" Click="CloseButton_Click"/>
            </Grid>

            <!-- 核心：支持层级折叠展开的任务列表 -->
            <ListBox Grid.Row="1" ItemsSource="{Binding Tasks}" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <!-- 每个大任务采用可折叠 Expander 包装 -->
                        <Expander Margin="0,0,0,10" Width="320">
                            <Expander.Header>
                                <Grid Width="250">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Orientation="Vertical">
                                        <TextBlock Text="{Binding Title}" FontSize="13" FontWeight="Bold" Foreground="{Binding DataContext.WidgetTextColor, RelativeSource={RelativeSource AncestorType=Window}}"/>
                                        <TextBlock Text="{Binding Priority, StringFormat=优先级: {0}}" FontSize="10" Foreground="#888888"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="已全部打卡" Foreground="#28A745" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"
                                               Visibility="{Binding IsCompleted, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                                </Grid>
                            </Expander.Header>
                            
                            <!-- 内部嵌套展现对应的子任务列表 -->
                            <ItemsControl ItemsSource="{Binding SubTasks}" Margin="20,5,0,5">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,4,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <!-- 子任务一键打卡复选框 -->
                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsCompleted, Mode=OneWay}" 
                                                      Command="{Binding DataContext.CompleteSubTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}" 
                                                      CommandParameter="{Binding}" VerticalAlignment="Center"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Title}" Margin="8,0,0,0" FontSize="12" VerticalAlignment="Center"
                                                       Foreground="{Binding DataContext.WidgetTextColor, RelativeSource={RelativeSource AncestorType=Window}}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                                <!-- 打卡后文字自动灰色斜体划线 -->
                                                                <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                                <Setter Property="Foreground" Value="#888888"/>
                                                            </DataTrigger>
                                                            <!-- 修正：将原本错误的 </Style.Triggers> 改为 </DataTrigger> 闭合 -->
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Border>
</Window>
