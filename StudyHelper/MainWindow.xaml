<Window x:Class="StudyHelper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="桌面看板" Height="450" Width="350"
        WindowStyle="None" 
        AllowsTransparency="True" 
        Background="Transparent" 
        ShowInTaskbar="False"
        WindowStartupLocation="Manual" Left="50" Top="50">

    <!-- 桌面半透明磨砂质感卡片布局 -->
    <Border Background="#CCFFFFFF" CornerRadius="12" Padding="15" BorderBrush="#20000000" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,10">
                <TextBlock Text="今日学习养成目标" FontWeight="Bold" FontSize="16" Foreground="#333333" VerticalAlignment="Center"/>
                <!-- 点击此按钮彻底关闭整个应用 -->
                <Button Content="×" HorizontalAlignment="Right" FontSize="18" Background="Transparent" BorderThickness="0" Cursor="Hand" Click="CloseButton_Click"/>
            </Grid>

            <!-- 此处展示大任务及 DDL [INFERRED] -->
            <StackPanel Grid.Row="1">
                <TextBlock Text="1. 算法刷题 (DDL: 20:00)" FontSize="14" Foreground="#444444" Margin="0,5,0,5"/>
                <TextBlock Text="2. 英语打卡 (DDL: 22:00)" FontSize="14" Foreground="#444444" Margin="0,5,0,5"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>