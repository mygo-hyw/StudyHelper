<Window x:Class="StudyHelper.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="桌面看板"
        Height="460"
        Width="360"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        WindowStartupLocation="Manual"
        Left="50"
        Top="50">
    <Window.Resources>
        <Style x:Key="TaskCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#EFFFFFFF"/>
            <Setter Property="BorderBrush" Value="#26000000"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDueSoon}" Value="True">
                    <Setter Property="Background" Value="#FFFFEFEF"/>
                    <Setter Property="BorderBrush" Value="#EFAAAA"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                    <Setter Property="Background" Value="#FFE7EAEE"/>
                    <Setter Property="BorderBrush" Value="#C9D0D8"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                    <Setter Property="Background" Value="#FFDDF8E7"/>
                    <Setter Property="BorderBrush" Value="#A7E2BC"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PriorityTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1D4ED8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Priority}" Value="高">
                    <Setter Property="Foreground" Value="#B91C1C"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Priority}" Value="低">
                    <Setter Property="Foreground" Value="#047857"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CardButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="28"/>
            <Setter Property="MinWidth" Value="52"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#2563EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#AEB8C5"/>
                                <Setter Property="BorderBrush" Value="#AEB8C5"/>
                                <Setter Property="Cursor" Value="Arrow"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="28"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Foreground" Value="#4B5563"/>
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Border Background="#CCFFFFFF"
            CornerRadius="12"
            Padding="14"
            BorderBrush="#20000000"
            BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="10"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <StackPanel>
                    <TextBlock Text="今日学习养成目标"
                               FontWeight="Bold"
                               FontSize="16"
                               Foreground="#1F2933"/>
                    <StackPanel Orientation="Horizontal"
                                Margin="0,3,0,0">
                        <TextBlock Text="连续打卡 "
                                   Foreground="#64748B"
                                   FontSize="12"/>
                        <TextBlock Text="{Binding StreakDays}"
                                   Foreground="#2563EB"
                                   FontSize="12"
                                   FontWeight="SemiBold"/>
                        <TextBlock Text=" 天"
                                   Foreground="#64748B"
                                   FontSize="12"/>
                    </StackPanel>
                </StackPanel>
                <Button Content="×"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Top"
                        Command="{Binding ExitApplicationCommand}"
                        Style="{StaticResource CloseButtonStyle}"/>
            </Grid>

            <ProgressBar Grid.Row="2"
                         Height="8"
                         Minimum="0"
                         Maximum="100"
                         Value="{Binding CompletionRate}"
                         Foreground="#2563EB"
                         Background="#E2E8F0"/>

            <ListBox Grid.Row="4"
                     ItemsSource="{Binding Tasks}"
                     BorderThickness="0"
                     Background="Transparent"
                     ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,0,8"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource TaskCardStyle}">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="8"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel>
                                    <TextBlock Text="{Binding Title}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="#263241"
                                               TextTrimming="CharacterEllipsis"/>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,5,0,0">
                                        <TextBlock Text="{Binding TargetTime, StringFormat=DDL：{0:MM-dd HH:mm}}"
                                                   FontSize="12"
                                                   Foreground="#64748B"/>
                                        <TextBlock Text="  /  "
                                                   FontSize="12"
                                                   Foreground="#94A3B8"/>
                                        <TextBlock Text="{Binding Priority, StringFormat=优先级：{0}}"
                                                   Style="{StaticResource PriorityTextStyle}"/>
                                    </StackPanel>
                                </StackPanel>

                                <Button Grid.Column="2"
                                        Content="完成"
                                        Command="{Binding DataContext.CompleteTaskCommand, RelativeSource={RelativeSource AncestorType=ListBox}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource CardButtonStyle}"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>
    </Border>
</Window>
