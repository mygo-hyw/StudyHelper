<Window x:Class="StudyHelper.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:local="clr-namespace:StudyHelper"
        Title="学习计划 - 设置中心"
        Height="680"
        Width="980"
        MinHeight="620"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        Background="Transparent"
        FontFamily="Microsoft YaHei UI">
    <Window.Resources>
        <SolidColorBrush x:Key="TextPrimaryBrush" Color="#17212F"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#647184"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#F4FFFFFF"/>
        <SolidColorBrush x:Key="LineBrush" Color="#E1E7EF"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#2563EB"/>

        <Style x:Key="PanelBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource PanelBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource LineBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="18"/>
        </Style>

        <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="17"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="Margin" Value="0,0,0,14"/>
        </Style>

        <Style x:Key="FieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="MetaTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="BorderBrush" Value="#C8D2DE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="Height" Value="38"/>
            <Setter Property="BorderBrush" Value="#C8D2DE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="38"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="BorderBrush" Value="#C8D2DE"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Height" Value="10"/>
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Background" Value="#E9EEF5"/>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="40"/>
            <Setter Property="Padding" Value="16,0"/>
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1D4ED8"/>
                                <Setter Property="BorderBrush" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Background" Value="#B8C0CC"/>
                                <Setter Property="BorderBrush" Value="#B8C0CC"/>
                                <Setter Property="Foreground" Value="#F7F9FC"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="QuietButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Height" Value="32"/>
            <Setter Property="Padding" Value="12,0"/>
            <Setter Property="Background" Value="#EEF4FF"/>
            <Setter Property="Foreground" Value="#1D4ED8"/>
            <Setter Property="BorderBrush" Value="#CFE0FF"/>
        </Style>

        <Style x:Key="ChromeButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="34"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#14000000"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TabItemStyle" TargetType="TabItem">
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="TabBorder"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0,0,0,2"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="TabBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PriorityBadgeStyle" TargetType="Border">
            <Setter Property="Background" Value="#E8F1FF"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="9,3"/>
            <Setter Property="MinWidth" Value="42"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Priority}" Value="高">
                    <Setter Property="Background" Value="#FFE8E8"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Priority}" Value="低">
                    <Setter Property="Background" Value="#E8F7EE"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PriorityTextStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#1D4ED8"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Priority}" Value="高">
                    <Setter Property="Foreground" Value="#B91C1C"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Priority}" Value="低">
                    <Setter Property="Foreground" Value="#047857"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="TaskCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#00FFFFFF"/>
            <Setter Property="BorderBrush" Value="#EDF1F6"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="Padding" Value="0,0,0,10"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsDueSoon}" Value="True">
                    <Setter Property="Background" Value="#FFF1F1"/>
                    <Setter Property="BorderBrush" Value="#F6B7B7"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="CornerRadius" Value="8"/>
                    <Setter Property="Padding" Value="12"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsOverdue}" Value="True">
                    <Setter Property="Background" Value="#ECEFF3"/>
                    <Setter Property="BorderBrush" Value="#CDD4DD"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="CornerRadius" Value="8"/>
                    <Setter Property="Padding" Value="12"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                    <Setter Property="Background" Value="#DDF8E7"/>
                    <Setter Property="BorderBrush" Value="#A7E2BC"/>
                    <Setter Property="BorderThickness" Value="1"/>
                    <Setter Property="CornerRadius" Value="8"/>
                    <Setter Property="Padding" Value="12"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SubTaskCardStyle" TargetType="Border">
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#E4EAF2"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Padding" Value="8,6"/>
            <Setter Property="Margin" Value="0,3,0,0"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                    <Setter Property="Background" Value="#E2F7EA"/>
                    <Setter Property="BorderBrush" Value="#B7E5C8"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="#CCFFFFFF"
            BorderBrush="#30FFFFFF"
            BorderThickness="1"
            CornerRadius="14"
            Padding="22"
            Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="24"
                              ShadowDepth="0"
                              Opacity="0.18"
                              Color="#000000"/>
        </Border.Effect>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="18"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <StackPanel>
                <TextBlock Text="托盘设置中心"
                           FontSize="25"
                           FontWeight="Bold"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
                <TextBlock Text="任务、提醒、打卡与数据分析"
                           FontSize="13"
                           Foreground="{StaticResource TextMutedBrush}"
                           Margin="0,5,0,0"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center">
                <Border Background="#EAF1FF"
                        CornerRadius="8"
                        Padding="12,7"
                        Margin="0,0,8,0">
                    <TextBlock Foreground="#1D4ED8"
                               FontWeight="SemiBold">
                        <Run Text="总任务 "/>
                        <Run Text="{Binding TotalAddedCount}"/>
                    </TextBlock>
                </Border>
                <Border Background="#EAF7EF"
                        CornerRadius="8"
                        Padding="12,7"
                        Margin="0,0,10,0">
                    <TextBlock Foreground="#047857"
                               FontWeight="SemiBold">
                        <Run Text="完成率 "/>
                        <Run Text="{Binding CompletionRate, StringFormat={}{0:F0}%}"/>
                    </TextBlock>
                </Border>
                <Button Content="─"
                        Click="MinimizeButton_Click"
                        Style="{StaticResource ChromeButtonStyle}"/>
                <Button Content="×"
                        Click="CloseButton_Click"
                        Style="{StaticResource ChromeButtonStyle}"/>
            </StackPanel>
        </Grid>

        <TabControl Grid.Row="2"
                    Background="Transparent"
                    BorderThickness="0"
                    ItemContainerStyle="{StaticResource TabItemStyle}">
            <TabItem Header="任务">
                <Grid Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="390"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource PanelBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="14"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="添加自定义任务"
                                       Style="{StaticResource SectionTitleStyle}"/>

                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto">
                                <StackPanel>
                                    <TextBlock Text="任务名称"
                                               Style="{StaticResource FieldLabelStyle}"/>
                                    <TextBox Text="{Binding NewTaskTitle, UpdateSourceTrigger=PropertyChanged}"
                                             MaxLength="60"
                                             Margin="0,0,0,14"/>

                                    <TextBlock Text="截止时间"
                                               Style="{StaticResource FieldLabelStyle}"/>
                                    <Border Background="#F8FBFF"
                                            BorderBrush="#D9E2EC"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="12"
                                            Margin="0,0,0,14">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="12"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <DatePicker SelectedDate="{Binding SelectedDate, Mode=TwoWay}"
                                                        HorizontalAlignment="Stretch"/>

                                            <Grid Grid.Row="2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="10"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="10"/>
                                                    <ColumnDefinition Width="112"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="小时"
                                                               Style="{StaticResource FieldLabelStyle}"/>
                                                    <ComboBox ItemsSource="{Binding Hours}"
                                                              SelectedItem="{Binding SelectedHour, Mode=TwoWay}"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2">
                                                    <TextBlock Text="分钟"
                                                               Style="{StaticResource FieldLabelStyle}"/>
                                                    <ComboBox ItemsSource="{Binding Minutes}"
                                                              SelectedItem="{Binding SelectedMinute, Mode=TwoWay}"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="4">
                                                    <TextBlock Text="优先级"
                                                               Style="{StaticResource FieldLabelStyle}"/>
                                                    <ComboBox ItemsSource="{Binding Priorities}"
                                                              SelectedItem="{Binding SelectedPriority, Mode=TwoWay}"/>
                                                </StackPanel>
                                            </Grid>
                                        </Grid>
                                    </Border>

                                    <CheckBox Content="加入复习提醒"
                                              IsChecked="{Binding NeedsReview, Mode=TwoWay}"
                                              Foreground="#344256"
                                              Margin="0,0,0,14"/>

                                    <TextBlock Text="子任务"
                                               Style="{StaticResource FieldLabelStyle}"/>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="44"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBox Text="{Binding NewSubTaskTitle, UpdateSourceTrigger=PropertyChanged}"
                                                 MaxLength="50"/>
                                        <Button Grid.Column="2"
                                                Content="+"
                                                Command="{Binding AddSubTaskCommand}"
                                                Style="{StaticResource PrimaryButtonStyle}"/>
                                    </Grid>

                                    <ListBox ItemsSource="{Binding DraftSubTasks}"
                                             MinHeight="44"
                                             MaxHeight="150"
                                             BorderBrush="#E4EAF2"
                                             BorderThickness="1"
                                             Background="#80FFFFFF"
                                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                                        <ListBox.ItemContainerStyle>
                                            <Style TargetType="ListBoxItem">
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                            </Style>
                                        </ListBox.ItemContainerStyle>
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="8,6">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding Title}"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               TextTrimming="CharacterEllipsis"
                                                               VerticalAlignment="Center"/>
                                                    <Button Grid.Column="1"
                                                            Content="移除"
                                                            Command="{Binding DataContext.RemoveDraftSubTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource QuietButtonStyle}"
                                                            Margin="8,0,0,0"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </StackPanel>
                            </ScrollViewer>

                            <Button Grid.Row="3"
                                    Content="+ 添加任务"
                                    Command="{Binding AddTaskCommand}"
                                    Style="{StaticResource PrimaryButtonStyle}"/>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2"
                            Style="{StaticResource PanelBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Grid Grid.Row="0" Margin="0,0,0,12">
                                <TextBlock Text="任务清单"
                                           Style="{StaticResource SectionTitleStyle}"
                                           Margin="0"/>
                                <TextBlock HorizontalAlignment="Right"
                                           VerticalAlignment="Center"
                                           Style="{StaticResource MetaTextStyle}">
                                    <Run Text="{Binding TotalAddedCount}"/>
                                    <Run Text=" 项"/>
                                </TextBlock>
                            </Grid>

                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Tasks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource TaskCardStyle}"
                                                Margin="0,0,0,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="12"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding Title}"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <StackPanel Orientation="Horizontal"
                                                                Margin="0,6,0,0">
                                                        <TextBlock Text="{Binding TargetTime, StringFormat={}{0:yyyy-MM-dd HH:mm}}"
                                                                   Style="{StaticResource MetaTextStyle}"/>
                                                        <TextBlock Text="  /  "
                                                                   Foreground="#A3ADBA"
                                                                   FontSize="12"/>
                                                        <CheckBox Content="复习"
                                                                  IsChecked="{Binding NeedsReview}"
                                                                  IsEnabled="False"
                                                                  FontSize="12"
                                                                  Foreground="{StaticResource TextMutedBrush}"/>
                                                    </StackPanel>
                                                    <ItemsControl ItemsSource="{Binding SubTasks}"
                                                                  Margin="0,7,0,0">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Style="{StaticResource SubTaskCardStyle}">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Text="{Binding Title, StringFormat=- {0}}"
                                                                                   FontSize="12"
                                                                                   Foreground="{StaticResource TextMutedBrush}"
                                                                                   TextTrimming="CharacterEllipsis"
                                                                                   VerticalAlignment="Center"/>
                                                                        <Button Grid.Column="1"
                                                                                Content="完成"
                                                                                Command="{Binding DataContext.CompleteSubTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                CommandParameter="{Binding}"
                                                                                Style="{StaticResource QuietButtonStyle}"
                                                                                Margin="8,0,0,0"/>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2"
                                                            Orientation="Horizontal"
                                                            VerticalAlignment="Top">
                                                    <Border Style="{StaticResource PriorityBadgeStyle}"
                                                            Margin="0,0,8,0">
                                                        <TextBlock Text="{Binding Priority}"
                                                                   Style="{StaticResource PriorityTextStyle}"/>
                                                    </Border>
                                                    <Button Content="打卡"
                                                            Command="{Binding DataContext.CompleteTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource QuietButtonStyle}"/>
                                                    <Button Content="删除"
                                                            Command="{Binding DataContext.DeleteTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}"
                                                            Style="{StaticResource QuietButtonStyle}"
                                                            Margin="8,0,0,0"/>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="提醒">
                <Grid Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource PanelBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="优先级提醒策略"
                                       Style="{StaticResource SectionTitleStyle}"/>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="#FFE8E8"
                                        CornerRadius="12"
                                        Padding="9,4"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="高"
                                               Foreground="#B91C1C"
                                               FontWeight="SemiBold"/>
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Text="到期当天强提醒"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                            </Grid>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="#E8F1FF"
                                        CornerRadius="12"
                                        Padding="9,4"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="中"
                                               Foreground="#1D4ED8"
                                               FontWeight="SemiBold"/>
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Text="按固定间隔提醒"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                            </Grid>

                            <Grid Margin="0,0,0,18">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="70"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Border Background="#E8F7EE"
                                        CornerRadius="12"
                                        Padding="9,4"
                                        HorizontalAlignment="Left">
                                    <TextBlock Text="低"
                                               Foreground="#047857"
                                               FontWeight="SemiBold"/>
                                </Border>
                                <TextBlock Grid.Column="1"
                                           Text="低频提醒"
                                           VerticalAlignment="Center"
                                           Foreground="{StaticResource TextPrimaryBrush}"/>
                            </Grid>

                            <CheckBox Content="当前新任务开启复习提醒"
                                      IsChecked="{Binding NeedsReview, Mode=TwoWay}"
                                      Foreground="#344256"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Style="{StaticResource PanelBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="复习节奏"
                                       Style="{StaticResource SectionTitleStyle}"/>
                            <UniformGrid Columns="4" Margin="0,0,0,16">
                                <Border Background="#F1F5F9" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                                    <TextBlock Text="第 1 天" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                </Border>
                                <Border Background="#F1F5F9" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                                    <TextBlock Text="第 3 天" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                </Border>
                                <Border Background="#F1F5F9" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                                    <TextBlock Text="第 7 天" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                </Border>
                                <Border Background="#F1F5F9" CornerRadius="8" Padding="12">
                                    <TextBlock Text="第 15 天" HorizontalAlignment="Center" FontWeight="SemiBold"/>
                                </Border>
                            </UniformGrid>
                            <TextBlock Text="后端按 NeedsReview 与完成日期生成复习任务"
                                       Style="{StaticResource MetaTextStyle}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="打卡">
                <Grid Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="330"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource PanelBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="打卡日历"
                                       Style="{StaticResource SectionTitleStyle}"/>
                            <Calendar SelectionMode="MultipleRange"
                                      local:CalendarSelection.SelectedDates="{Binding HistoryCheckInDates}"
                                      HorizontalAlignment="Stretch"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Style="{StaticResource PanelBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="今日任务打卡"
                                       Style="{StaticResource SectionTitleStyle}"/>

                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto">
                                <ItemsControl ItemsSource="{Binding Tasks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource TaskCardStyle}"
                                                Margin="0,0,0,10">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Title}"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding TargetTime, StringFormat=DDL：{0:yyyy-MM-dd HH:mm}}"
                                                               Style="{StaticResource MetaTextStyle}"
                                                               Margin="0,4,0,0"/>
                                                    <ItemsControl ItemsSource="{Binding SubTasks}"
                                                                  Margin="0,7,0,0">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Style="{StaticResource SubTaskCardStyle}">
                                                                    <Grid>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="*"/>
                                                                            <ColumnDefinition Width="Auto"/>
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Text="{Binding Title, StringFormat=- {0}}"
                                                                                   FontSize="12"
                                                                                   Foreground="{StaticResource TextMutedBrush}"
                                                                                   TextTrimming="CharacterEllipsis"
                                                                                   VerticalAlignment="Center"/>
                                                                        <Button Grid.Column="1"
                                                                                Content="完成"
                                                                                Command="{Binding DataContext.CompleteSubTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                                CommandParameter="{Binding}"
                                                                                Style="{StaticResource QuietButtonStyle}"
                                                                                Margin="8,0,0,0"/>
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </StackPanel>
                                                <Button Grid.Column="1"
                                                        Content="完成"
                                                        Command="{Binding DataContext.CompleteTaskCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                        CommandParameter="{Binding}"
                                                        Style="{StaticResource QuietButtonStyle}"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>

            <TabItem Header="分析">
                <Grid Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320"/>
                        <ColumnDefinition Width="18"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0"
                            Style="{StaticResource PanelBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="完成概览"
                                       Style="{StaticResource SectionTitleStyle}"/>
                            <TextBlock Text="{Binding CompletionRate, StringFormat={}{0:F1}%}"
                                       FontSize="40"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,8"/>
                            <ProgressBar Minimum="0"
                                         Maximum="100"
                                         Value="{Binding CompletionRate}"
                                         Margin="0,0,0,18"/>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="已添加"
                                               Style="{StaticResource MetaTextStyle}"/>
                                    <TextBlock Text="{Binding TotalAddedCount}"
                                               FontSize="24"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="当前进度"
                                               Style="{StaticResource MetaTextStyle}"/>
                                    <TextBlock Text="{Binding CompletionRate, StringFormat={}{0:F0}%}"
                                               FontSize="24"
                                               FontWeight="SemiBold"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2"
                            Style="{StaticResource PanelBorderStyle}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="任务统计图"
                                       Style="{StaticResource SectionTitleStyle}"/>
                            <lvc:CartesianChart Grid.Row="1"
                                                Series="{Binding Series}"/>
                        </Grid>
                    </Border>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
    </Border>
</Window>
